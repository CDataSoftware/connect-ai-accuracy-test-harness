# =============================================================================
# LangChain MCP Testing Harness - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials
# This harness supports testing multiple MCP providers against multiple data sources
# =============================================================================

# OpenAI API Configuration (Required for all tests)
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# Default MCP Server Selection
# =============================================================================
# Choose default MCP server: connectai, crm_native, erp_native, ipaas, mcp_gateway, unified_api
MCP_SERVER_TYPE=connectai

# =============================================================================
# CData Connect AI - Basic Authentication
# =============================================================================
# Required when using provider: connectai
# CData Connect AI supports CRM, Project Management, Data Warehouse, ERP, and 100+ sources
# CONNECTAI_AUTH should be base64 encoded "username:personal_access_token"
CONNECTAI_MCP_URL=https://mcp.cloud.cdata.com/mcp
CONNECTAI_AUTH=your_base64_encoded_credentials_here

# =============================================================================
# CRM Native MCP Server
# =============================================================================
# Required when using provider: crm_native
# Only supports CRM data (deals, contacts, companies, etc.)
CRM_NATIVE_MCP_URL=https://example.com/mcp
CRM_NATIVE_BEARER_TOKEN=your_bearer_token_here

# =============================================================================
# ERP Native MCP Server
# =============================================================================
# Required when using provider: erp_native
# Only supports ERP data (accounts, orders, bins, charges, etc.)
ERP_NATIVE_MCP_URL=https://your_account_id.myerp.com/mcp
ERP_NATIVE_BEARER_TOKEN=your_bearer_token_here

# =============================================================================
# iPaaS Provider MCP Server
# =============================================================================
# Required when using provider: ipaas
# Get your MCP URL from your iPaaS provider's MCP integration settings
# The URL may contain embedded authentication token
IPAAS_MCP_URL=https://example.com/mcp

# =============================================================================
# MCP Gateway Server
# =============================================================================
# Required when using provider: mcp_gateway
# Get your MCP URL from your MCP gateway dashboard
MCP_GATEWAY_URL=https://example.com/mcp

# =============================================================================
# Unified API MCP Server
# =============================================================================
# Required when using provider: unified_api
# Uses stdio transport via npx mcp-remote
# Get your URL and token from your unified API provider dashboard
UNIFIED_API_MCP_URL=https://example.com/mcp
UNIFIED_API_AUTH_TOKEN=your_api_key_here

# =============================================================================
# LLM Configuration
# =============================================================================
DEFAULT_MODEL=gpt-5
DEFAULT_TEMPERATURE=0.2
DEFAULT_MAX_TOKENS=1000

# =============================================================================
# Optional Configuration
# =============================================================================
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
